# VLESS UUID (必需)
# 格式：xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
UUID=

# 服务器端口 (必需)
# 范围：1-65535
PORT=3000

# 服务器域名 (必需)
# 例如：example.com
TUNNEL_DOMAIN=

# Cloudflare Tunnel 配置
TUNNEL_TOKEN=your-cloudflare-tunnel-token-here

# 服务器名称 (可选)
# 默认为主机名
NAME=

# VLESS 路径前缀 (可选)
# 默认为 /work-tunnel-
VLESS_PATH_PREFIX=

# 最大内存用量（字节，可选）
# 默认 512MB = 536870912
MAX_MEMORY_USAGE=